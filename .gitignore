*.tfstate.backup

# Variables con valores sensibles
*.tfvars
*.tfvars.json

# Plan files
*.tfplan
*.plan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log
crash.log
crash.*.log

